<section class="zbcl-section" id="zbcl-{{ section.id }}">

  {%- if section.settings.eyebrow != blank -%}
    <div class="zbcl-eyebrow-wrap">
      <span class="zbcl-eyebrow">{{ section.settings.eyebrow }}</span>
    </div>
  {%- endif -%}

  {%- if section.settings.title != blank -%}
    <div class="zbcl-header">
      <h2 class="zbcl-title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="zbcl-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="zbcl-grid zbcl-grid--{{ section.blocks.size }}">
    {%- for block in section.blocks -%}
      {%- assign col = collections[block.settings.collection] -%}
      {%- assign label = block.settings.label | default: col.title -%}
      {%- assign tag = block.settings.tag -%}

      <a
        href="{{ col.url }}"
        class="zbcl-card {% if forloop.first %}zbcl-card--featured{% endif %}"
        {{ block.shopify_attributes }}
        aria-label="{{ label }}"
      >
        <div class="zbcl-card__media">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ label }}" class="zbcl-card__img" width="900" loading="lazy">
          {%- elsif col.featured_image -%}
            <img src="{{ col.featured_image | image_url: width: 900 }}" alt="{{ label }}" class="zbcl-card__img" width="900" loading="lazy">
          {%- else -%}
            <div class="zbcl-card__placeholder">{{ 'collection-1' | placeholder_svg_tag }}</div>
          {%- endif -%}

          <div class="zbcl-card__content">
            {%- if tag != blank -%}
              <span class="zbcl-card__tag">{{ tag }}</span>
            {%- endif -%}
            <h3 class="zbcl-card__name">{{ label }}</h3>
            {%- if col.products_count > 0 -%}
              <span class="zbcl-card__count">{{ col.products_count }} products</span>
            {%- endif -%}
            <span class="zbcl-card__cta">
              Shop Now
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </div>
      </a>

    {%- endfor -%}
  </div>

</section>

<style>
.zbcl-section { padding: 48px 20px 56px; max-width: 1280px; margin: 0 auto; }
.zbcl-eyebrow-wrap { text-align: center; margin-bottom: 12px; }
.zbcl-eyebrow { display: inline-block; font-size: 11px; font-weight: 600; letter-spacing: 0.13em; text-transform: uppercase; color: #6B1A2A; background: rgba(107,26,42,0.07); padding: 4px 14px; border-radius: 100px; }
.zbcl-header { text-align: center; margin-bottom: 28px; }
.zbcl-title { font-size: clamp(24px, 3.5vw, 38px); font-weight: 700; color: #1A1A1A; letter-spacing: -0.025em; line-height: 1.1; margin: 0 0 8px; }
.zbcl-subtitle { font-size: 15px; color: #6B6B6B; margin: 0 auto; max-width: 440px; line-height: 1.6; }

.zbcl-grid { display: grid; gap: 14px; }
.zbcl-grid--3 { grid-template-columns: 1.2fr 1fr; grid-template-rows: 1fr 1fr; height: 480px; }
.zbcl-grid--3 .zbcl-card--featured { grid-row: 1 / 3; }
.zbcl-grid--2 { grid-template-columns: 1fr 1fr; height: 360px; }
.zbcl-grid--4 { grid-template-columns: repeat(4, 1fr); height: 320px; }
.zbcl-grid--1 { grid-template-columns: 1fr; height: 400px; }

@media (max-width: 768px) {
  .zbcl-grid--3, .zbcl-grid--4 { grid-template-columns: 1fr 1fr; grid-template-rows: unset; height: unset; }
  .zbcl-grid--3 .zbcl-card--featured { grid-column: 1 / -1; grid-row: unset; }
  .zbcl-grid--2 { height: unset; }
  .zbcl-section { padding: 36px 14px 44px; }
}
@media (max-width: 480px) {
  .zbcl-grid--2, .zbcl-grid--3, .zbcl-grid--4 { grid-template-columns: 1fr; height: unset; }
}

.zbcl-card { display: block; text-decoration: none; border-radius: 22px; overflow: hidden; position: relative; background: #fff; border: 2px solid #D4A9B0; padding: 7px; height: 100%; box-shadow: 0 2px 16px rgba(107,26,42,0.07); transition: box-shadow 0.32s cubic-bezier(0.4,0,0.2,1), transform 0.32s cubic-bezier(0.4,0,0.2,1), border-color 0.28s; box-sizing: border-box; }
.zbcl-card:hover { box-shadow: 0 10px 36px rgba(107,26,42,0.18); transform: translateY(-3px); border-color: #6B1A2A; }

.zbcl-card__media { position: relative; width: 100%; height: 100%; border-radius: 16px; overflow: hidden; background: #F0EBE8; }
@media (max-width: 768px) { .zbcl-card__media { aspect-ratio: 4/3; height: unset; } }

.zbcl-card__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.55s cubic-bezier(0.4,0,0.2,1); }
.zbcl-card:hover .zbcl-card__img { transform: scale(1.05); }

.zbcl-card__content { position: absolute; bottom: 0; left: 0; right: 0; padding: 16px 18px 20px; display: flex; flex-direction: column; gap: 4px; background: rgba(15,5,8,0.42); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border-top: 1px solid rgba(255,255,255,0.12); border-radius: 0 0 16px 16px; }

.zbcl-card__tag { display: inline-block; font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #fff; background: rgba(107,26,42,0.80); backdrop-filter: blur(4px); padding: 3px 10px; border-radius: 100px; width: fit-content; margin-bottom: 3px; }
.zbcl-card__name { font-size: clamp(16px, 2vw, 22px); font-weight: 700; color: #fff; margin: 0; line-height: 1.15; letter-spacing: -0.01em; }
.zbcl-card__count { font-size: 12px; color: rgba(255,255,255,0.75); letter-spacing: 0.02em; }
.zbcl-card__cta { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: #fff; border-bottom: 1.5px solid rgba(255,255,255,0.5); padding-bottom: 1px; width: fit-content; margin-top: 6px; transition: border-color 0.2s, gap 0.2s; letter-spacing: 0.03em; }
.zbcl-card:hover .zbcl-card__cta { border-color: #fff; gap: 10px; }

.zbcl-card__placeholder { width: 100%; height: 100%; background: #E8E0DA; display: flex; align-items: center; justify-content: center; }
.zbcl-card__placeholder svg { width: 40%; height: 40%; opacity: 0.25; }
</style>

{% schema %}
{
  "name": "ZB — Collection Listing",
  "tag": "section",
  "class": "zbcl-section-wrapper",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "Browse" },
    { "type": "text", "id": "title", "label": "Section title", "default": "Our Collections" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Everyday beauty, thoughtfully curated." }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Custom image (overrides collection image)" },
        { "type": "text", "id": "label", "label": "Custom label (overrides collection title)" },
        { "type": "text", "id": "tag", "label": "Tag pill (e.g. New, Trending, Staff Pick)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ZB — Collection Listing",
      "category": "Zeid Beauty",
      "blocks": [
        { "type": "collection_card" },
        { "type": "collection_card" },
        { "type": "collection_card" }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}