<div class="zbnfb-outer" id="zbnfb-{{ section.id }}">
  <div class="zbnfb-layout">

    <!-- LEFT: Image -->
    <div class="zbnfb-image-col">
      {%- if section.settings.image != blank -%}
        <div class="zbnfb-img-wrap">
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.heading }}"
            loading="lazy"
            width="800"
          >
          {%- if section.settings.image_caption != blank -%}
            <span class="zbnfb-img-caption">{{ section.settings.image_caption }}</span>
          {%- endif -%}
        </div>
      {%- else -%}
        <div class="zbnfb-img-placeholder">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect x="6" y="6" width="36" height="36" rx="8" stroke="#D4A9B0" stroke-width="2"/><circle cx="18" cy="18" r="4" stroke="#D4A9B0" stroke-width="2"/><path d="M6 32l10-10 8 8 6-6 12 12" stroke="#D4A9B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <p>Upload product image in Customizer</p>
        </div>
      {%- endif -%}
    </div>

    <!-- RIGHT: Benefits -->
    <div class="zbnfb-content-col">

      {%- if section.settings.eyebrow != blank -%}
        <span class="zbnfb-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <h2 class="zbnfb-heading">{{ section.settings.heading }}</h2>

      {%- if section.settings.subheading != blank -%}
        <p class="zbnfb-subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <!-- Stats row -->
      <div class="zbnfb-stats">
        {%- if section.settings.stat_1_number != blank -%}
          <div class="zbnfb-stat">
            <span class="zbnfb-stat-num">{{ section.settings.stat_1_number }}</span>
            <span class="zbnfb-stat-label">{{ section.settings.stat_1_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_2_number != blank -%}
          <div class="zbnfb-stat">
            <span class="zbnfb-stat-num">{{ section.settings.stat_2_number }}</span>
            <span class="zbnfb-stat-label">{{ section.settings.stat_2_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_3_number != blank -%}
          <div class="zbnfb-stat">
            <span class="zbnfb-stat-num">{{ section.settings.stat_3_number }}</span>
            <span class="zbnfb-stat-label">{{ section.settings.stat_3_label }}</span>
          </div>
        {%- endif -%}
      </div>

      <!-- Benefit rows -->
      <div class="zbnfb-benefits">

        {%- if section.settings.benefit_1_title != blank -%}
          <div class="zbnfb-benefit">
            <div class="zbnfb-benefit-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#6B1A2A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="zbnfb-benefit-text">
              <span class="zbnfb-benefit-title">{{ section.settings.benefit_1_title }}</span>
              {%- if section.settings.benefit_1_desc != blank -%}
                <span class="zbnfb-benefit-desc">{{ section.settings.benefit_1_desc }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.benefit_2_title != blank -%}
          <div class="zbnfb-benefit">
            <div class="zbnfb-benefit-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#6B1A2A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="zbnfb-benefit-text">
              <span class="zbnfb-benefit-title">{{ section.settings.benefit_2_title }}</span>
              {%- if section.settings.benefit_2_desc != blank -%}
                <span class="zbnfb-benefit-desc">{{ section.settings.benefit_2_desc }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.benefit_3_title != blank -%}
          <div class="zbnfb-benefit">
            <div class="zbnfb-benefit-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#6B1A2A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="zbnfb-benefit-text">
              <span class="zbnfb-benefit-title">{{ section.settings.benefit_3_title }}</span>
              {%- if section.settings.benefit_3_desc != blank -%}
                <span class="zbnfb-benefit-desc">{{ section.settings.benefit_3_desc }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.benefit_4_title != blank -%}
          <div class="zbnfb-benefit">
            <div class="zbnfb-benefit-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#6B1A2A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="zbnfb-benefit-text">
              <span class="zbnfb-benefit-title">{{ section.settings.benefit_4_title }}</span>
              {%- if section.settings.benefit_4_desc != blank -%}
                <span class="zbnfb-benefit-desc">{{ section.settings.benefit_4_desc }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.benefit_5_title != blank -%}
          <div class="zbnfb-benefit">
            <div class="zbnfb-benefit-icon">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 8l4 4 8-8" stroke="#6B1A2A" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="zbnfb-benefit-text">
              <span class="zbnfb-benefit-title">{{ section.settings.benefit_5_title }}</span>
              {%- if section.settings.benefit_5_desc != blank -%}
                <span class="zbnfb-benefit-desc">{{ section.settings.benefit_5_desc }}</span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>

      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: product.url }}" class="zbnfb-cta">
          {{ section.settings.cta_label }}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M1 8h14M9 2l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      {%- endif -%}

    </div>

  </div>
</div>

<style>
/* ============================================================
   ZB — Neck & Face Device Benefits Section
   ============================================================ */

.zbnfb-outer {
  max-width: 1280px;
  margin: 0 auto;
  padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
}

/* Layout */
.zbnfb-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 52px;
  align-items: center;
  background: #fff;
  border: 1.5px solid #D4A9B0;
  border-radius: 28px;
  padding: 44px 48px;
  box-shadow: 0 4px 32px rgba(107, 26, 42, 0.07);
}

/* Image col */
.zbnfb-image-col { position: relative; }
.zbnfb-img-wrap {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  border: 1.5px solid #EDE4DF;
  box-shadow: 0 8px 32px rgba(107, 26, 42, 0.1);
}
.zbnfb-img-wrap img {
  width: 100%;
  display: block;
  object-fit: cover;
}
.zbnfb-img-caption {
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 11px;
  font-weight: 600;
  color: #fff;
  background: rgba(107, 26, 42, 0.75);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  padding: 5px 14px;
  border-radius: 100px;
  white-space: nowrap;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.zbnfb-img-placeholder {
  aspect-ratio: 4/5;
  background: #FAF7F4;
  border: 1.5px dashed #D4A9B0;
  border-radius: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  color: #C8A8B0;
  font-size: 13px;
}

/* Content col */
.zbnfb-content-col {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* Eyebrow */
.zbnfb-eyebrow {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.13em;
  text-transform: uppercase;
  color: #6B1A2A;
  background: rgba(107, 26, 42, 0.07);
  padding: 4px 14px;
  border-radius: 100px;
  width: fit-content;
}

/* Heading */
.zbnfb-heading {
  font-size: clamp(22px, 2.8vw, 34px);
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: -0.025em;
  line-height: 1.12;
  margin: 0;
}

/* Subheading */
.zbnfb-subheading {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
  margin: 0;
}

/* Stats row */
.zbnfb-stats {
  display: flex;
  gap: 0;
  background: #FAF7F4;
  border: 1.5px solid #EDE4DF;
  border-radius: 16px;
  overflow: hidden;
}
.zbnfb-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16px 12px;
  gap: 4px;
  border-right: 1px solid #EDE4DF;
}
.zbnfb-stat:last-child { border-right: none; }
.zbnfb-stat-num {
  font-size: 24px;
  font-weight: 800;
  color: #6B1A2A;
  letter-spacing: -0.02em;
  line-height: 1;
}
.zbnfb-stat-label {
  font-size: 11px;
  color: #888;
  text-align: center;
  line-height: 1.35;
  font-weight: 500;
}

/* Benefits list */
.zbnfb-benefits {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.zbnfb-benefit {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}
.zbnfb-benefit-icon {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: rgba(107, 26, 42, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}
.zbnfb-benefit-text {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.zbnfb-benefit-title {
  font-size: 14px;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 1.3;
}
.zbnfb-benefit-desc {
  font-size: 12px;
  color: #777;
  line-height: 1.5;
}

/* CTA */
.zbnfb-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #6B1A2A;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding: 14px 26px;
  border-radius: 100px;
  text-decoration: none;
  width: fit-content;
  transition: background 0.22s, transform 0.16s, gap 0.2s;
}
.zbnfb-cta:hover { background: #4A1020; transform: translateY(-2px); gap: 14px; }

/* Mobile */
@media (max-width: 768px) {
  .zbnfb-layout {
    grid-template-columns: 1fr;
    gap: 28px;
    padding: 24px 20px;
    border-radius: 20px;
  }
  .zbnfb-stat-num { font-size: 20px; }
  .zbnfb-cta { width: 100%; justify-content: center; }
}
@media (max-width: 480px) {
  .zbnfb-outer { padding: 24px 12px 28px; }
  .zbnfb-layout { padding: 18px 16px; border-radius: 16px; gap: 20px; }
}
</style>

