chTab('ease', event)\">Ease of Use<\/button>\n    <button class=\"reviews-tab\" onclick=\"switchTab('repurchase', event)\">Would Buy Again<\/button>\n  <\/div>\n\n  <div class=\"reviews-grid\" id=\"reviews-grid\"><\/div>\n\n<\/div>\n\n<script>\n  const allReviews = {\n    results: [\n      { text: \"My hairline looks instantly fuller. I couldn’t believe the difference!\", author: \"Karim M.\" },\n      { text: \"Covered my thinning spots in seconds. Super impressed.\", author: \"Omar K.\" },\n      { text: \"Big confidence boost. My hair looks thicker right away.\", author: \"Hassan R.\" },\n    ],\n    natural: [\n      { text: \"Blends perfectly with my hair. No one can tell I used anything.\", author: \"Rami H.\" },\n      { text: \"Looks completely natural, even up close.\", author: \"Ali A.\" },\n      { text: \"Way better than fibers. This actually looks real.\", author: \"Fadi F.\" },\n    ],\n    longlasting: [\n      { text: \"Stayed on all day, even in the heat.\", author: \"Jad S.\" },\n      { text: \"Sweat-proof for real. Didn’t move at all.\", author: \"Tarek M.\" },\n      { text: \"No smudging, no fading. Solid product.\", author: \"Ziad A.\" },\n    ],\n    ease: [\n      { text: \"Takes less than 10 seconds to apply.\", author: \"Nabil T.\" },\n      { text: \"Super easy, no mess like sprays or fibers.\", author: \"Youssef K.\" },\n      { text: \"Perfect for quick daily use.\", author: \"Samir B.\" },\n    ],\n    repurchase: [\n      { text: \"Already ordered another one.\", author: \"Walid N.\" },\n      { text: \"This is now part of my daily routine.\", author: \"Maher F.\" },\n      { text: \"Definitely buying again. Worth it.\", author: \"Rony L.\" },\n    ]\n  };\n\n  function switchTab(tab, event) {\n    document.querySelectorAll('.reviews-tab').forEach(btn => btn.classList.remove('active'));\n    event.target.classList.add('active');\n\n    const reviews = allReviews[tab];\n\n    document.getElementById('reviews-grid').innerHTML = reviews.