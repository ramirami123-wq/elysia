r-spacing: -0.02em;\n}\n.zbnf-rev-stars { color: #6B1A2A; font-size: 18px; letter-spacing: 2px; }\n.zbnf-rev-count { font-size: 13px; color: #888; }\n\n.zbnf-rev-grid {\n  display: flex; flex-direction: column; gap: 10px;\n}\n\n.zbnf-rev-card {\n  background: #FAF7F4; border: 1.5px solid #EDE4DF;\n  border-radius: 16px; padding: 18px 20px;\n  transition: border-color 0.2s, box-shadow 0.2s;\n}\n.zbnf-rev-card:hover {\n  border-color: #D4A9B0;\n  box-shadow: 0 3px 16px rgba(107,26,42,0.07);\n}\n\n.zbnf-rev-top {\n  display: flex; align-items: center; gap: 10px; margin-bottom: 10px;\n}\n.zbnf-rev-avatar {\n  width: 36px; height: 36px; border-radius: 50%;\n  background: #6B1A2A; color: #fff;\n  font-size: 14px; font-weight: 700;\n  display: flex; align-items: center; justify-content: center;\n  flex-shrink: 0;\n}\n.zbnf-rev-name { font-size: 13px; font-weight: 600; color: #1A1A1A; }\n.zbnf-rev-stars-sm { color: #6B1A2A; font-size: 12px; letter-spacing: 1px; }\n.zbnf-rev-verified {\n  margin-left: auto; font-size: 11px; font-weight: 600;\n  color: #2A6B3A; background: rgba(42,107,58,0.08);\n  padding: 2px 8px; border-radius: 100px;\n}\n.zbnf-rev-title {\n  font-size: 14px; font-weight: 700; color: #1A1A1A;\n  margin: 0 0 6px; line-height: 1.3;\n}\n.zbnf-rev-body {\n  font-size: 13px; color: #555; line-height: 1.65; margin: 0 0 10px;\n}\n.zbnf-rev-date { font-size: 11px; color: #bbb; }\n\n@media (max-width: 600px) {\n  .zbnf-rev-card { padding: 14px 14px; border-radius: 14px; }\n}\n<\/style>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"custom_liquid_UktVme":{"type":"custom-liquid","name":"F&Q","settings":{"custom_liquid":"<div class=\"zb-faq-block\" id=\"zb-faq-nf\">\n\n  <div class=\"zb-faq-block-title\">FAQs<\/div>\n\n  <div class=\"zb-faq-item\">\n    <button class=\"zb-faq-q\" aria-expanded=\"false\">\n      <span>How often should I use the device?<\/span>\n      <div class=\"zb-faq-icon\"><svg class=\"zb-plus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M7 1v12M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><svg class=\"zb-minus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><\/div>\n    <\/button>\n    <div class=\"zb-faq-a\"><p>For best results, use daily for 5–10 minutes per session. Most users see noticeable improvement in skin firmness and tone within 3–4 weeks of consistent use.<\/p><\/div>\n  <\/div>\n\n  <div class=\"zb-faq-item\">\n    <button class=\"zb-faq-q\" aria-expanded=\"false\">\n      <span>Which intensity level should I start with?<\/span>\n      <div class=\"zb-faq-icon\"><svg class=\"zb-plus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M7 1v12M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><svg class=\"zb-minus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><\/div>\n    <\/button>\n    <div class=\"zb-faq-a\"><p>Always start on Level 1, especially if you have sensitive skin. Once your skin adapts after a few sessions, you can gradually increase to Level 2 or 3 for deeper stimulation.<\/p><\/div>\n  <\/div>\n\n  <div class=\"zb-faq-item\">\n    <button class=\"zb-faq-q\" aria-expanded=\"false\">\n      <span>Do I need to apply serum or cream before using it?<\/span>\n      <div class=\"zb-faq-icon\"><svg class=\"zb-plus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M7 1v12M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><svg class=\"zb-minus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><\/div>\n    <\/button>\n    <div class=\"zb-faq-a\"><p>Yes — always apply a serum or moisturizer before use. The heating function opens pores and the ultrasonic vibration drives the product deeper into the skin, so your skincare works significantly harder.<\/p><\/div>\n  <\/div>\n\n  <div class=\"zb-faq-item\">\n    <button class=\"zb-faq-q\" aria-expanded=\"false\">\n      <span>Is it safe for sensitive skin?<\/span>\n      <div class=\"zb-faq-icon\"><svg class=\"zb-plus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M7 1v12M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><svg class=\"zb-minus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><\/div>\n    <\/button>\n    <div class=\"zb-faq-a\"><p>Yes. The device has 3 adjustable intensity levels specifically to accommodate sensitive skin. Start low and increase gradually. If you have a skin condition or are pregnant, consult your doctor first.<\/p><\/div>\n  <\/div>\n\n  <div class=\"zb-faq-item\">\n    <button class=\"zb-faq-q\" aria-expanded=\"false\">\n      <span>Can I use it on my neck as well as my face?<\/span>\n      <div class=\"zb-faq-icon\"><svg class=\"zb-plus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M7 1v12M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><svg class=\"zb-minus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><\/div>\n    <\/button>\n    <div class=\"zb-faq-a\"><p>Absolutely — the curved ergonomic design is specifically shaped to fit the jaw, neck, and cheeks. The neck is actually one of the first areas to show aging, so it's a great area to focus on.<\/p><\/div>\n  <\/div>\n\n  <div class=\"zb-faq-item\">\n    <button class=\"zb-faq-q\" aria-expanded=\"false\">\n      <span>How long until I see results?<\/span>\n      <div class=\"zb-faq-icon\"><svg class=\"zb-plus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M7 1v12M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><svg class=\"zb-minus\" width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M1 7h12\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"\/><\/svg><\/div>\n    <\/button>\n    <div class=\"zb-faq-a\"><p>Many users notice an immediate glow after the first session from improved circulation. Visible firmness and reduction in fine lines typically appear after 3–4 weeks of daily use.<\/p><\/div>\n  <\/div>\n\n<\/div>\n\n<style>\n.zb-faq-block { padding: 8px 0 4px; }\n.zb-faq-block-title { font-size: 18px; font-weight: 700; color: #1A1A1A; margin-bottom: 14px; letter-spacing: -0.01em; }\n.zb-faq-item { border: 1.5px solid #EDE4DF; border-radius: 14px; margin-bottom: 8px; overflow: hidden; background: #fff; transition: border-color 0.2s, box-shadow 0.2s; }\n.zb-faq-item.zb-open { border-color: #D4A9B0; box-shadow: 0 3px 16px rgba(107,26,42,0.08); }\n.zb-faq-q { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 15px 18px; background: none; border: none; cursor: pointer; text-align: left; }\n.zb-faq-q span { font-size: 14px; font-weight: 500; color: #1A1A1A; line-height: 1.4; flex: 1; }\n.zb-faq-item.zb-open .zb-faq-q span { color: #6B1A2A; }\n.zb-faq-icon { width: 30px; height: 30px; border-radius: 50%; border: 1.5px solid #D4A9B0; display: flex; align-items: center; justify-content: center; flex-shrink: 0; color: #6B1A2A; transition: background 0.2s, border-color 0.2s, color 0.2s; }\n.zb-faq-item.zb-open .zb-faq-icon { background: #6B1A2A; border-color: #6B1A2A; color: #fff; }\n.zb-minus { display: none; }\n.zb-faq-item.zb-open .zb-plus  { display: none; }\n.zb-faq-item.zb-open .zb-minus { display: block; }\n.zb-faq-a { max-height: 0; overflow: hidden; transition: max-height 0.32s cubic-bezier(0.4,0,0.2,1); }\n.zb-faq-item.zb-open .zb-faq-a { max-height: 300px; }\n.zb-faq-a p { font-size: 13px; color: #555; line-height: 1.65; margin: 0; padding: 0 18px 16px; border-top: 1px solid #F5EEF0; padding-top: 12px; }\n@media (max-width: 600px) { .zb-faq-q { padding: 13px 14px; } .zb-faq-a p { padding: 0 14px 14px; padding-top: 10px; } }\n<\/style>\n\n<script>\n(function(){\n  var wrap = document.getElementById('zb-faq-nf');\n  if (!wrap) return;\n  wrap.querySelectorAll('.zb-faq-q').forEach(function(btn){\n    btn.addEventListener('click', function(){\n      var item = btn.closest('.zb-faq-item');\n      var isOpen = item.classList.contains('zb-open');\n      wrap.querySelectorAll('.zb-faq-item').forEach(function(i){ i.classList.remove('zb-open'); i.querySelector('.zb-faq-q').setAttribute('aria-expanded','false'); });\n      if (!isOpen){ item.classList.add('zb-open'); btn.setAttribute('aria-expanded','true'); }\n    });\n  });\n})();\n<\/script>","full_width":false,"show_divider":false,"padding_top":36,"padding_bottom":36}},"product-recommendations":{"type":"product-recommendations","disabled":true,"settings":{"product_list_limit":4,"show_divider":false,"heading":"You May Also Like","heading_size":"h1","heading_alignment":"center","heading_tag":"h2","columns_mobile":"1","swipe_on_mobile":true,"image_ratio":"portrait","image_position":"center center","enable_image_fill":true,"show_secondary_image":true,"show_vendor":true,"show_rating":true,"show_quick_buy":false,"enable_quick_view":true,"enable_color_swatches":true,"enable_countdown":true,"padding_top":36,"padding_bottom":36}},"guarantees_4jiQMN":{"type":"guarantees","blocks":{"guarantee_tXThNR":{"type":"guarantee","settings":{"icon":"lock","icon_size":"medium","custom_icon":"","title":"Secure Checkout","title_size":"h3","text":""}},"guarantee_EUwJCY":{"type":"guarantee","settings":{"icon":"truck","icon_size":"medium","cust