>\n\n  <script>\n    (function () {\n      const durationHours = 12; \/\/ change if needed\n      const endAt = Date.now() + durationHours * 60 * 60 * 1000;\n\n      const h = document.getElementById(\"st-hours\");\n      const m = document.getElementById(\"st-mins\");\n      const s = document.getElementById(\"st-secs\");\n\n      const pad = n => String(n).padStart(2, \"0\");\n\n      function update(){\n        let diff = endAt - Date.now();\n        if(diff < 0) diff = 0;\n\n        const total = Math.floor(diff \/ 1000);\n        h.textContent = pad(Math.floor(total \/ 3600));\n        m.textContent = pad(Math.floor((total % 3600) \/ 60));\n        s.textContent = pad(total % 60);\n\n        if(diff === 0) clearInterval(timer);\n      }\n\n      update();\n      const timer = setInterval(update, 1000);\n    })();\n  <\/script>\n<\/section>"}},"custom_liquid_h8EyY7":{"type":"custom_liquid","settings":{"custom_liquid":"<div style=\"padding: 12px; text-align: left; background-color: #f9f9f9; font-size: 15px; border-radius: 12px; margin-top: 10px; margin-bottom: 10px; line-height: 1.6;\">\n\n<span style=\"font-weight: bold;\">💎 Instantly Fuller-Looking Hair<\/span> – Cover thin areas in seconds and enjoy a thicker, denser appearance immediately.<br><br>\n\n<span style=\"font-weight: bold;\">🪞 Confidence From Every Angle<\/span> – No more worrying about visible scalp under bright lights, cameras, or close conversations.<br><br>\n\n<span style=\"font-weight: bold;\">⚡ Sharp, Clean Hairline Fast<\/span> – Step out looking polished and well-groomed without complicated routines.<br><br>\n\n<span style=\"font-weight: bold;\">📸 Camera-Ready All Day<\/span> – Feel secure in photos, meetings, and social events knowing your hair looks natural and full.\n\n<\/div>"}},"variant_picker":{"type":"variant_picker","settings":{"show_variant_labels":true,"picker_type":"button","enable_color_swatches":true,"swatches_source":"file","swatch_type":"round","enable_swatch_cross":true,"enab