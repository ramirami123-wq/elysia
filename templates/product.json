      "settings": {
        "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .hurry-section {\n    background: #ffffff;\n    padding: 40px 24px;\n    width: 100%;\n    box-sizing: border-box;\n    font-family: 'Barlow', Arial, sans-serif;\n    text-align: center;\n  }\n\n  .hurry-title {\n    font-size: 36px;\n    font-weight: 900;\n    color: #111111;\n    text-transform: uppercase;\n    line-height: 1.1;\n    margin: 0 0 12px;\n  }\n\n  .hurry-subtitle {\n    font-size: 15px;\n    color: #333333;\n    margin: 0 0 28px;\n  }\n\n  .hurry-bullets {\n    list-style: none;\n    padding: 0;\n    margin: 0 auto;\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    text-align: left;\n    max-width: 620px;\n  }\n\n  .hurry-bullet {\n    display: flex;\n    align-items: flex-start;\n    gap: 14px;\n    font-size: 15px;\n    line-height: 1.5;\n    color: #222222;\n  }\n\n  .hurry-check {\n    width: 28px;\n    height: 28px;\n    flex-shrink: 0;\n  }\n\n  @media (max-width: 600px) {\n    .hurry-section {\n      padding: 32px 18px;\n    }\n\n    .hurry-title {\n      font-size: 29px;\n    }\n  }\n</style>\n\n<div class=\"hurry-section\">\n\n  <h2 class=\"hurry-title\">\n    Lift, Firm & Rejuvenate<br>\n    Your Skin at Home\n  </h2>\n\n  <p class=\"hurry-subtitle\">\n    Use our LED + Microcurrent Beauty Device to...\n  </p>\n\n  <ul class=\"hurry-bullets\">\n\n    <li class=\"hurry-bullet\">\n      <svg class=\"hurry-check\" viewBox=\"0 0 28 28\" fill=\"none\">\n        <circle cx=\"14\" cy=\"14\" r=\"13\" fill=\"#7a9471\"/>\n        <path d=\"M8 14.5L12 18.5L20 10\" stroke=\"#fff\" stroke-width=\"2.2\"/>\n      </svg>\n      <span>Help reduce the appearance of fine lines and wrinkles for smoother-looking skin.</span>\n    </li>\n\n    <li class=\"hurry-bullet\">\n      <svg class=\"hurry-check\" viewBox=\"0 0 28 28\" fill=\"none\">\n        <circle cx=\"14\" cy=\"14\" r=\"13\" fill=\"#7a9471\"/>\n        <path d=\"M8 14.5L12 18.5L20 10\" stroke=\"#fff\" stroke-width=\"2.2\"/>\n      </svg>\n      <span>Lift and firm the face, jawline, cheeks, and neck with microcurrent technology.</span>\n    </li>\n\n    <li class=\"hurry-bullet\">\n      <svg class=\"hurry-check\" viewBox=\"0 0 28 28\" fill=\"none\">\n        <circle cx=\"14\" cy=\"14\" r=\"13\" fill=\"#7a9471\"/>\n        <path d=\"M8 14.5L12 18.5L20 10\" stroke=\"#fff\" stroke-width=\"2.2\"/>\n      </svg>\n      <span>Improve the absorption of your favorite serums and creams using gentle heat and vibration.</span>\n    </li>\n\n    <li class=\"hurry-bullet\">\n      <svg class=\"hurry-check\" viewBox=\"0 0 28 28\" fill=\"none\">\n        <circle cx=\"14\" cy=\"14\" r=\"13\" fill=\"#7a9471\"/>\n        <path d=\"M8 14.5L12 18.5L20 10\" stroke=\"#fff\" stroke-width=\"2.2\"/>\n      </svg>\n      <span>Enjoy an easy 5–10 minute skincare treatment without expensive salon appointments.</span>\n    </li>\n\n  </ul>\n</div>",
        "full_width": false,
        "show_divider": false,
        "padding_top": 36,
        "padding_bottom": 36
      }
