      "settings": {
        "custom_liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n\n<style>\n  .faq-section {\n    background: #ffffff;\n    padding: 48px 16px;\n    width: 100%;\n    box-sizing: border-box;\n    font-family: 'Barlow', Arial, sans-serif;\n  }\n\n  .faq-inner {\n    max-width: 720px;\n    margin: 0 auto;\n  }\n\n  .faq-title {\n    font-size: 28px;\n    font-weight: 900;\n    color: #111111;\n    text-transform: uppercase;\n    text-align: center;\n    margin: 0 0 8px;\n  }\n\n  .faq-subtitle {\n    font-size: 15px;\n    color: #666666;\n    text-align: center;\n    margin: 0 0 36px;\n  }\n\n  .faq-item {\n    border-bottom: 1px solid #dce5d9;\n  }\n\n  .faq-question {\n    width: 100%;\n    background: none;\n    border: none;\n    padding: 18px 4px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    cursor: pointer;\n    font-family: inherit;\n    font-size: 15px;\n    font-weight: 700;\n    color: #222222;\n    text-align: left;\n  }\n\n  .faq-icon {\n    width: 28px;\n    height: 28px;\n    flex-shrink: 0;\n    border-radius: 50%;\n    background: #f4f7f2;\n    border: 2px solid #b9c9b4;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    color: #7a9471;\n    transition: 0.3s ease;\n  }\n\n  .faq-question.open .faq-icon {\n    background: #7a9471;\n    border-color: #7a9471;\n    color: #ffffff;\n    transform: rotate(45deg);\n  }\n\n  .faq-answer {\n    max-height: 0;\n    overflow: hidden;\n    transition: max-height 0.3s ease;\n  }\n\n  .faq-answer.open {\n    max-height: 300px;\n    padding-bottom: 18px;\n  }\n\n  .faq-answer p {\n    margin: 0;\n    padding: 0 4px;\n    font-size: 14px;\n    line-height: 1.6;\n    color: #555555;\n  }\n\n  @media (max-width: 600px) {\n    .faq-section {\n      padding: 38px 18px;\n    }\n\n    .faq-title {\n      font-size: 24px;\n    }\n  }\n</style>\n\n<div class=\"faq-section\">\n  <div class=\"faq-inner\">\n\n    <h2 class=\"faq-title\">Frequently Asked Questions</h2>\n    <p class=\"faq-subtitle\">\n      Everything you need to know about your LED + Microcurrent Beauty Device ✨\n    </p>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" type=\"button\" onclick=\"toggleFaq(this)\">\n        How do I use the beauty device?\n        <span class=\"faq-icon\">+</span>\n      </button>\n\n      <div class=\"faq-answer\">\n        <p>\n          Clean your face and neck, apply your preferred serum or moisturizer,\n          select an intensity level, and gently move the device upward across\n          the skin for 5–10 minutes.\n        </p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" type=\"button\" onclick=\"toggleFaq(this)\">\n        How often should I use it?\n        <span class=\"faq-icon\">+</span>\n      </button>\n\n      <div class=\"faq-answer\">\n        <p>\n          Use it 3–5 times per week, depending on your skin sensitivity and\n          comfort. Begin with the lowest intensity level and gradually increase\n          when needed.\n        </p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" type=\"button\" onclick=\"toggleFaq(this)\">\n        Can I use it on both my face and neck?\n        <span class=\"faq-icon\">+</span>\n      </button>\n\n      <div class=\"faq-answer\">\n        <p>\n          Yes. Its ergonomic shape is designed for the cheeks, jawline,\n          forehead, chin, and neck area.\n        </p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" type=\"button\" onclick=\"toggleFaq(this)\">\n        Should I apply a serum before using it?\n        <span class=\"faq-icon\">+</span>\n      </button>\n\n      <div class=\"faq-answer\">\n        <p>\n          Yes. Apply a water-based serum, gel, or moisturizer before treatment\n          so the device glides smoothly and helps improve product absorption.\n        </p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" type=\"button\" onclick=\"toggleFaq(this)\">\n        What do the three intensity levels do?\n        <span class=\"faq-icon\">+</span>\n      </button>\n\n      <div class=\"faq-answer\">\n        <p>\n          The adjustable levels allow you to choose a gentle, medium, or\n          stronger treatment based on your comfort and skin sensitivity.\n        </p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" type=\"button\" onclick=\"toggleFaq(this)\">\n        When can I expect visible results?\n        <span class=\"faq-icon\">+</span>\n      </button>\n\n      <div class=\"faq-answer\">\n        <p>\n          Your skin may feel refreshed after use, while improvements in the\n          appearance of firmness and fine lines usually require consistent use\n          over time.\n        </p>\n      </div>\n    </div>\n\n    <div class=\"faq-item\">\n      <button class=\"faq-question\" type=\"button\" onclick=\"toggleFaq(this)\">\n        Is it suitable for sensitive skin?\n        <span class=\"faq-icon\">+</span>\n      </button>\n\n      <div class=\"faq-answer\">\n        <p>\n          Start with the lowest setting and a short session. Stop using the\n          device if you notice discomfort or irritation.\n        </p>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n  function toggleFaq(button) {\n    const faqSection = button.closest('.faq-section');\n    const answer = button.nextElementSibling;\n    const isOpen = button.classList.contains('open');\n\n    faqSection.querySelectorAll('.faq-question').forEach(function(question) {\n      question.classList.remove('open');\n    });\n\n    faqSection.querySelectorAll('.faq-answer').forEach(function(item) {\n      item.classList.remove('open');\n    });\n\n    if (!isOpen) {\n      button.classList.add('open');\n      answer.classList.add('open');\n    }\n  }\n</script>",
